# Main Ghostty config
# Split keybindings into a separate file to keep this easier to scan.

# Appearance
font-family = "FiraCode Nerd Font Mono"
font-size = 20
theme = "catppuccin-mocha.conf"
cursor-style = "block"

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true
confirm-close-surface = false

# Terminal behavior
scrollback-limit = 10000
shell-integration = zsh

# Extra config files
config-file = keybinds
